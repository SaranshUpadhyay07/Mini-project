# ── MongoDB ───────────────────────────────────────────────────────────────────
# MongoDB connection string (same as /api service)
# Important: This MUST match the MONGO_URI used in /api
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── AI Model Keys ─────────────────────────────────────────────────────────────
# Google Gemini API key (used by chatbot_agent.py and planner agents)
# Get it from https://aistudio.google.com/app/apikey
Gemini_api_key=

# Groq API key (used by editor_agent.py for fast LLM inference)
# Get it from https://console.groq.com/keys
Groq_api_key=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production set this to your deployed frontend URL, e.g.:
#   CORS_ORIGIN=https://your-app.vercel.app
# Multiple origins example:
#   CORS_ORIGIN=https://your-app.vercel.app,https://your-app.netlify.app
CORS_ORIGIN=http://localhost:5173

# ── Server ────────────────────────────────────────────────────────────────────
# Port the FastAPI/uvicorn server listens on (default: 8000)
PORT=8000
