# ── Mappls Map SDK ────────────────────────────────────────────────────────────
# Get keys from https://apis.mappls.com/console/
VITE_MAPPLS_API_KEY=
VITE_MAPPLS_CLIENT_KEY=
VITE_MAPPLS_CLIENT_SECRET=

# ── Service URLs ──────────────────────────────────────────────────────────────
# Express API (api/ service)
VITE_API_URL=http://localhost:5000
# FastAPI Agent service (Agent/ service)
VITE_AGENT_URL=http://localhost:8000

# ── Firebase Client Config ────────────────────────────────────────────────────
# Find these in Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=   # optional – Analytics only
