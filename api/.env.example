# ── MongoDB ───────────────────────────────────────────────────────────────────
# Full MongoDB Atlas (or self-hosted) connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Mappls API ────────────────────────────────────────────────────────────────
# Server-side Mappls REST API key (used in places.controller.js)
MAPPLS_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production set this to your deployed frontend URL, e.g.:
#   CORS_ORIGIN=https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ── Redis (optional – used for location caching in socketHandler.js) ──────────
# If Redis is not available the server falls back to Socket.io-only mode.
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
